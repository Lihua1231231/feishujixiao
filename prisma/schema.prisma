generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ USERS & ORG ============

model User {
  id            String   @id @default(cuid())
  feishuOpenId  String   @unique
  feishuUnionId String?
  name          String
  email         String?
  avatarUrl     String?
  department    String   @default("")
  jobTitle      String?
  role          String   @default("EMPLOYEE") // EMPLOYEE, SUPERVISOR, HRBP, ADMIN
  supervisorId  String?
  supervisor    User?    @relation("Supervision", fields: [supervisorId], references: [id])
  subordinates  User[]   @relation("Supervision")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  selfEvals            SelfEvaluation[]
  peerReviewsGiven     PeerReview[]          @relation("Reviewer")
  peerReviewsReceived  PeerReview[]          @relation("Reviewee")
  supervisorEvals      SupervisorEval[]      @relation("Evaluator")
  supervisorEvalsRecv  SupervisorEval[]      @relation("Evaluated")
  nominationsGiven     ReviewerNomination[]  @relation("Nominator")
  nominationsReceived  ReviewerNomination[]  @relation("Nominee")
  meetingsAsEmployee   Meeting[]             @relation("MeetingEmployee")
  meetingsAsSupervisor Meeting[]             @relation("MeetingSupervisor")
  calibrationResults   CalibrationResult[]
  appeals              Appeal[]
}

// ============ REVIEW CYCLE ============

model ReviewCycle {
  id               String   @id @default(cuid())
  name             String
  selfEvalStart    DateTime
  selfEvalEnd      DateTime
  peerReviewStart  DateTime
  peerReviewEnd    DateTime
  supervisorStart  DateTime
  supervisorEnd    DateTime
  calibrationStart DateTime
  calibrationEnd   DateTime
  meetingStart     DateTime
  meetingEnd       DateTime
  appealStart      DateTime?
  appealEnd        DateTime?
  status           String   @default("DRAFT") // DRAFT, SELF_EVAL, PEER_REVIEW, SUPERVISOR_EVAL, CALIBRATION, MEETING, APPEAL, ARCHIVED
  createdAt        DateTime @default(now())

  selfEvals       SelfEvaluation[]
  peerReviews     PeerReview[]
  supervisorEvals SupervisorEval[]
  nominations     ReviewerNomination[]
  meetings        Meeting[]
  calibrations    CalibrationResult[]
  appeals         Appeal[]
  finalReviewConfig FinalReviewConfig?
  finalReviewOpinions FinalReviewOpinion[]
  leaderFinalReviews LeaderFinalReview[]
  finalReviewConfirmations FinalReviewConfirmation[]
  scoreNormalizationSnapshots ScoreNormalizationSnapshot[]
  scoreNormalizationApplications ScoreNormalizationApplication[]
}

// ============ MODULE 1: SELF-EVALUATION ============

model SelfEvaluation {
  id              String    @id @default(cuid())
  cycleId         String
  cycle           ReviewCycle @relation(fields: [cycleId], references: [id])
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  importedContent String    @default("")
  importedAt      DateTime?
  sourceUrl       String?
  status          String    @default("DRAFT") // DRAFT, SUBMITTED
  submittedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([cycleId, userId])
}

// ============ MODULE 2: 360 PEER REVIEW ============

model ReviewerNomination {
  id               String   @id @default(cuid())
  cycleId          String
  cycle            ReviewCycle @relation(fields: [cycleId], references: [id])
  nominatorId      String
  nominator        User     @relation("Nominator", fields: [nominatorId], references: [id])
  nomineeId        String
  nominee          User     @relation("Nominee", fields: [nomineeId], references: [id])
  supervisorStatus String   @default("PENDING") // PENDING, APPROVED, REJECTED
  nomineeStatus    String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  declineReason    String   @default("")
  createdAt        DateTime @default(now())

  @@unique([cycleId, nominatorId, nomineeId])
}

model PeerReview {
  id                  String    @id @default(cuid())
  cycleId             String
  cycle               ReviewCycle @relation(fields: [cycleId], references: [id])
  reviewerId          String
  reviewer            User      @relation("Reviewer", fields: [reviewerId], references: [id])
  revieweeId          String
  reviewee            User      @relation("Reviewee", fields: [revieweeId], references: [id])
  outputScore         Int?      // 业绩产出质量 1-5
  outputComment       String    @default("")
  collaborationScore  Int?      // 协作配合度 1-5
  collaborationComment String   @default("")
  valuesScore         Int?      // 价值观践行 1-5
  valuesComment       String    @default("")
  innovationScore     Int?      // 可选（旧字段，保留兼容）
  innovationComment   String    @default("")
  // 新维度（与绩效初评一致）
  performanceStars    Int?      // 业绩产出
  performanceComment  String    @default("")
  comprehensiveStars  Int?      // 综合能力
  comprehensiveComment String   @default("")
  learningStars       Int?      // 学习能力
  learningComment     String    @default("")
  adaptabilityStars   Int?      // 适应能力
  adaptabilityComment String    @default("")
  abilityComment      String    @default("")
  candidStars         Int?      // 坦诚真实
  candidComment       String    @default("")
  progressStars       Int?      // 极致进取
  progressComment     String    @default("")
  altruismStars       Int?      // 成就利他
  altruismComment     String    @default("")
  rootStars           Int?      // ROOT
  rootComment         String    @default("")
  declinedAt          DateTime?
  declineReason       String    @default("")
  status              String    @default("DRAFT") // DRAFT, SUBMITTED, DECLINED
  submittedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([cycleId, reviewerId, revieweeId])
}

// ============ MODULE 3: SUPERVISOR EVALUATION ============

model SupervisorEval {
  id                 String    @id @default(cuid())
  cycleId            String
  cycle              ReviewCycle @relation(fields: [cycleId], references: [id])
  evaluatorId        String
  evaluator          User      @relation("Evaluator", fields: [evaluatorId], references: [id])
  employeeId         String
  employee           User      @relation("Evaluated", fields: [employeeId], references: [id])
  performanceStars   Int?      // 业绩产出50%，1-5星
  performanceComment String    @default("")
  abilityStars       Int?      // 个人能力30%，1-5星（由3个子维度1:1:1加权计算）
  abilityComment     String    @default("")
  comprehensiveStars Int?      // 综合能力 1-5星
  learningStars      Int?      // 学习能力 1-5星
  adaptabilityStars  Int?      // 适应能力 1-5星
  valuesStars        Int?      // 价值观20%，1-5星（由4个子维度1:1:1:1加权计算）
  valuesComment      String    @default("")
  candidStars        Int?      // 坦诚真实 1-5星
  candidComment      String    @default("")
  progressStars      Int?      // 极致进取 1-5星
  progressComment    String    @default("")
  altruismStars      Int?      // 成就利他 1-5星
  altruismComment    String    @default("")
  rootStars          Int?      // ROOT 1-5星
  rootComment        String    @default("")
  weightedScore      Float?    // 系统自动计算
  status             String    @default("DRAFT") // DRAFT, SUBMITTED
  submittedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([cycleId, employeeId, evaluatorId])
  @@index([cycleId, employeeId])
  @@index([cycleId, evaluatorId])
}

// ============ MODULE 4: CALIBRATION ============

model CalibrationResult {
  id            String    @id @default(cuid())
  cycleId       String
  cycle         ReviewCycle @relation(fields: [cycleId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  proposedStars Float?
  finalStars    Int?
  adjustedBy    String?
  adjustReason  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([cycleId, userId])
}

// ============ MODULE 4.5: SCORE NORMALIZATION LAYER ============

model ScoreNormalizationSnapshot {
  id              String   @id @default(cuid())
  cycleId         String
  cycle           ReviewCycle @relation(fields: [cycleId], references: [id])
  source          String
  strategy        String   @default("RANK_BUCKET")
  targetBucketCount Int    @default(5)
  rawRecordCount  Int
  createdAt       DateTime @default(now())

  entries         ScoreNormalizationEntry[]
  applications    ScoreNormalizationApplication[]

  @@unique([id, cycleId, source])
  @@index([cycleId, source])
  @@index([cycleId, createdAt])
}

model ScoreNormalizationEntry {
  id              String   @id @default(cuid())
  snapshotId      String
  snapshot        ScoreNormalizationSnapshot @relation(fields: [snapshotId], references: [id])
  sourceRecordId  String
  subjectId       String
  subjectName     String   @default("")
  rawScore        Float?
  rankIndex       Int?
  bucketIndex     Int?
  bucketLabel     String   @default("")
  normalizedScore Float?
  createdAt       DateTime @default(now())

  @@unique([snapshotId, sourceRecordId])
  @@index([snapshotId, bucketIndex])
}

model ScoreNormalizationApplication {
  id            String   @id @default(cuid())
  cycleId       String
  cycle         ReviewCycle @relation(fields: [cycleId], references: [id])
  source        String
  snapshotId    String
  snapshot      ScoreNormalizationSnapshot @relation(fields: [snapshotId, cycleId, source], references: [id, cycleId, source])
  appliedAt     DateTime @default(now())
  revertedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([cycleId, source])
  @@index([snapshotId])
}

// ============ MODULE 4.6: FINAL REVIEW WORKSPACE ============

model FinalReviewConfig {
  id                      String      @id @default(cuid())
  cycleId                 String      @unique
  cycle                   ReviewCycle @relation(fields: [cycleId], references: [id])
  accessUserIds           String      @default("[]")
  finalizerUserIds        String      @default("[]")
  leaderEvaluatorUserIds  String      @default("[]")
  leaderSubjectUserIds    String      @default("[]")
  employeeSubjectUserIds  String      @default("[]")
  referenceStarRanges     String      @default("[]")
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model FinalReviewOpinion {
  id            String   @id @default(cuid())
  cycleId       String
  cycle         ReviewCycle @relation(fields: [cycleId], references: [id])
  employeeId    String
  reviewerId    String
  decision      String   @default("PENDING") // PENDING, AGREE, OVERRIDE
  suggestedStars Int?
  reason        String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([cycleId, employeeId, reviewerId])
  @@index([cycleId, employeeId])
  @@index([cycleId, reviewerId])
}

model LeaderFinalReview {
  id                 String   @id @default(cuid())
  cycleId            String
  cycle              ReviewCycle @relation(fields: [cycleId], references: [id])
  employeeId         String
  evaluatorId        String
  performanceStars   Int?
  performanceComment String   @default("")
  abilityStars       Int?
  abilityComment     String   @default("")
  comprehensiveStars Int?
  learningStars      Int?
  adaptabilityStars  Int?
  valuesStars        Int?
  valuesComment      String   @default("")
  candidStars        Int?
  candidComment      String   @default("")
  progressStars      Int?
  progressComment    String   @default("")
  altruismStars      Int?
  altruismComment    String   @default("")
  rootStars          Int?
  rootComment        String   @default("")
  weightedScore      Float?
  status             String   @default("DRAFT") // DRAFT, SUBMITTED
  submittedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([cycleId, employeeId, evaluatorId])
  @@index([cycleId, employeeId])
  @@index([cycleId, evaluatorId])
}

model FinalReviewConfirmation {
  id           String   @id @default(cuid())
  cycleId      String
  cycle        ReviewCycle @relation(fields: [cycleId], references: [id])
  userId       String
  confirmerId  String
  scope        String   // EMPLOYEE, LEADER
  officialStars Int
  reason       String
  createdAt    DateTime @default(now())

  @@index([cycleId, userId, scope])
  @@index([cycleId, confirmerId, scope])
}

// ============ MODULE 5: 1-ON-1 MEETING ============

model Meeting {
  id           String    @id @default(cuid())
  cycleId      String
  cycle        ReviewCycle @relation(fields: [cycleId], references: [id])
  employeeId   String
  employee     User      @relation("MeetingEmployee", fields: [employeeId], references: [id])
  supervisorId String
  supervisor   User      @relation("MeetingSupervisor", fields: [supervisorId], references: [id])
  meetingDate  DateTime?
  notes        String    @default("")
  employeeAck  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([cycleId, employeeId])
}

// ============ MODULE 6: APPEAL ============

model Appeal {
  id         String    @id @default(cuid())
  cycleId    String
  cycle      ReviewCycle @relation(fields: [cycleId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  reason     String    @default("")
  status     String    @default("PENDING") // PENDING, APPROVED, REJECTED
  resolution String    @default("")
  handledBy  String?
  handledAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([cycleId, userId])
}
